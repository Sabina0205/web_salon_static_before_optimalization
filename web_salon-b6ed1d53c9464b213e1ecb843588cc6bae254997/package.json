{
  "dependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "scripts": {
    "dev": "npx @tailwindcss/cli -i ./src/input.css -o ./src/output.css --watch",
    "dev:baseline": "npx @tailwindcss/cli -i ./src/input-baseline.css -o ./src/output-baseline.css --watch",
    "build": "npx @tailwindcss/cli -i ./src/input.css -o ./src/output.css",
    "build:baseline": "npx tailwindcss -i ./src/input-baseline.css -o ./dist/output-baseline.min.css --minify --content './baseline.html'",
    "prettier": "npx prettier --write src/**/*.html"
  },
  "prettier": {
    "plugins": ["prettier-plugin-tailwindcss"],
    "tailwindStylesheet": "./src/input.css"
  }
}




